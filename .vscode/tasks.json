{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build with g++",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "if not exist \"${workspaceFolder}\\build\" mkdir \"${workspaceFolder}\\build\" && C:\\msys64\\ucrt64\\bin\\g++.exe -std=c++20 -Wall -Wextra -Wshadow -g \"${file}\" -o \"${workspaceFolder}\\build\\${fileBasenameNoExtension}.exe\""
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}